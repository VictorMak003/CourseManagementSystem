@model SchoolManagementSystem.ViewModels.StudentVM;

@{
    ViewData["Title"] = "Student";
}
<div class="main-container">
    <div class="left-container">
        <div class="student-list">
            <div class="search-container">
                <form class="search" asp-controller="Nav" asp-action="Student" method="GET">
                    <img src="~/images/search-icon.png" alt="search-icon" />
                    <input type="text" name="search" placeholder="Search for Student" />
                    <button type="submit">Search</button>
                </form>
                <button class="add_btn">+</button>
            </div>

            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Student Number</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th><a class="reset" asp-controller="Nav" asp-action="Student"><img src="~/images/restart-icon.png" alt="restart-icon" /></a></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Students != null)
                    {
                        if (Model.Students.Count() > 0)
                        {
                            @foreach (var student in Model.Students)
                            {

                                <tr class="edit_btn" data-id="@student.Id">
                                    <td>@student.Id</td>
                                    <td>@student.StudNum</td>
                                    <td>@student.FirstName @student.LastName</td>
                                    <td colspan="2">@student.Email</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">No students found</td>
                            </tr>
                        }
                        
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">Error Retrieving Students</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="student-details">
        </div>
    </div>


    <div class="right-container">
        <div class="default-form"></div>
        <div class="create-form">
            <h2>Add Student</h2>
            <form asp-controller="Student" asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="form-group mb-3">
                    <input asp-for="NewStudent.StudNum" placeholder="Student Number" class="form-control">
                    <span asp-validation-for="NewStudent.StudNum" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <input asp-for="NewStudent.FirstName" placeholder="First Name" class="form-control">
                    <span asp-validation-for="NewStudent.FirstName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <input asp-for="NewStudent.LastName" placeholder="Last Name" class="form-control">
                    <span asp-validation-for="NewStudent.LastName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <input asp-for="NewStudent.Email" placeholder="Email" class="form-control">
                    <span asp-validation-for="NewStudent.Email" class="text-danger"></span>
                </div>

                <div class="form_btns">
                    <button type="submit" class="submit_btn">Submit</button>
                    <a class="btn cancel_btn" asp-controller="Nav" asp-action="Student" role="button">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
        <div class="edit-form">
            @if(@Model.NewStudent != null)
            {
            <script src="~/js/site.js"></script>
            <script>
                    showForm(document.getElementById("edit-form"));
            </script>
                <h2>Edit Student</h2>
            <form asp-controller="Student" asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="@Model.NewStudent.Id" value="@Model.NewStudent.Id" />
                <div class="form-group mb-3">
                        <input asp-for="@Model.NewStudent.StudNum" placeholder="Student Number" value="@Model.NewStudent.StudNum" class="form-control">
                        <span asp-validation-for="@Model.NewStudent.StudNum" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                        <input asp-for="@Model.NewStudent.FirstName" placeholder="First Name" value="@Model.NewStudent.FirstName" class="form-control">
                        <span asp-validation-for="@Model.NewStudent.FirstName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                        <input asp-for="@Model.NewStudent.LastName" placeholder="Last Name" value="@Model.NewStudent.LastName" class="form-control">
                        <span asp-validation-for="@Model.NewStudent.LastName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                        <input asp-for="@Model.NewStudent.Email" placeholder="Email" value="@Model.NewStudent.Email" class="form-control">
                        <span asp-validation-for="@Model.NewStudent.Email" class="text-danger"></span>
                </div>

                <div class="form_btns">
                    <button type="submit" class="submit_btn">Submit</button>
                    <a class="btn cancel_btn" asp-controller="Nav" asp-action="Student" role="button">
                        Cancel
                    </a>
                </div>
            </form>
            }
        </div>
        <div class="delete-form">
        </div>
    </div>
</div>


